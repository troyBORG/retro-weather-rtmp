# Copy to `.env` and set your ZIP. `.env` is gitignored.
LOCATION=60601

# Optional: IANA timezone (e.g. America/Chicago). If unset, the streamer picks TZ from the US ZIP above.
# TZ=America/Chicago

# Page to capture (default: Weather.com RetroCast). For WeatherStar 4000+, use Sharing → Copy Permalink
# in the app, then set (use quotes if the URL contains &):
# TARGET_URL=
# SKIP_START_RETROCAST_BUTTON=true
# SKIP_UNMUTE=false

# Optional: unmute automation (ms). Increase if mute control appears late.
# UNMUTE_INITIAL_DELAY_MS=14000
# UNMUTE_RETRY_INTERVAL_MS=7000
# UNMUTE_MAX_PASSES=18
