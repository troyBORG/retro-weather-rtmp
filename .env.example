# Copy to `.env` and set your ZIP. `.env` is gitignored.
LOCATION=60601

# Optional: IANA timezone (e.g. America/Chicago). If unset, the streamer picks TZ from the US ZIP above.
# TZ=America/Chicago

# Page to capture (default: Weather.com RetroCast). For WeatherStar 4000+, set a full URL from the site
# (Share / permalink) and use SKIP_START_RETROCAST_BUTTON=true — example:
# TARGET_URL=https://weatherstar.netbymatt.com/?hazards-checkbox=true&current-weather-checkbox=false&settings-wide-checkbox=true&settings-kiosk-checkbox=false&settings-speed-select=1.25&settings-units-select=us&latLonQuery=Your+City%2C+ST%2C+USA&latLon=%7B%22lat%22%3A39.0000%2C%22lon%22%3A-98.0000%7D
# SKIP_START_RETROCAST_BUTTON=true
# SKIP_UNMUTE=false

# Optional: unmute automation (ms). Increase if mute control appears late.
# UNMUTE_INITIAL_DELAY_MS=14000
# UNMUTE_RETRY_INTERVAL_MS=7000
# UNMUTE_MAX_PASSES=18
